{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DisateQ VENDOR™",
  "version": "0.1.0",
  "identifier": "com.disateq.vendor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "DisateQ VENDOR™",
        "width": 740,
        "height": 520,
        "decorations": false,
        "resizable": false,
        "fullscreen": false,
        "maximized": false,
        "center": true,
        "closable": false,
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["data/catalogo_digemid.sqlite"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
